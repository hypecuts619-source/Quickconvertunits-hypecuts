{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)-to-(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=31536000, stale-while-revalidate=59"
        }
      ]
    },
    {
      "source": "/convert-(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=31536000, stale-while-revalidate=59"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/ads.txt", "destination": "/ads.txt" },
    { "source": "/manifest.json", "destination": "/manifest.json" },
    { "source": "/favicon.svg", "destination": "/favicon.svg" },
    { "source": "/sitemap-programmatic.xml", "destination": "/sitemap-programmatic.xml" },
    { "source": "/google15107b17e9305211.html", "destination": "/google15107b17e9305211.html" },
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
